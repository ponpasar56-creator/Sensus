<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes, viewport-fit=cover">
    <title>Sensus Keluarga JATIM | Google Maps Accurate Geocoding</title>
    <link rel="manifest" href="manifest.json">
    <meta name="theme-color" content="#3498db">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="Sensus JATIM">
    <!-- Leaflet (OpenStreetMap) -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <!-- Leaflet Control Geocoder (untuk pencarian alamat) -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet-control-geocoder/dist/Control.Geocoder.css" />
    <script src="https://unpkg.com/leaflet-control-geocoder/dist/Control.Geocoder.js"></script>
    <style>
        * { box-sizing: border-box; }
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            margin: 0;
            padding: 20px;
            min-height: 100vh;
        }
        .main-container {
            max-width: 1400px;
            margin: 0 auto;
            background: white;
            border-radius: 16px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.3);
            overflow: hidden;
            padding: 20px;
        }
        h1 { margin: 0 0 5px 0; color: #2c3e50; font-size: 28px; }
        .subtitle { color: #7f8c8d; margin-bottom: 25px; border-bottom: 2px solid #ecf0f1; padding-bottom: 10px; }
        .button-panel { display: flex; flex-wrap: wrap; gap: 12px; margin-bottom: 20px; }
        .btn { padding: 10px 20px; border: none; border-radius: 8px; cursor: pointer; font-size: 14px; font-weight: 600; transition: all 0.3s ease; color: white; }
        .btn-primary { background-color: #3498db; }
        .btn-primary:hover { background-color: #2980b9; }
        .btn-success { background-color: #27ae60; }
        .btn-success:hover { background-color: #229954; }
        .btn-warning { background-color: #f39c12; }
        .btn-warning:hover { background-color: #e67e22; }
        .btn-danger { background-color: #e74c3c; }
        .btn-danger:hover { background-color: #c0392b; }
        .btn-info { background-color: #1abc9c; }
        .btn-info:hover { background-color: #16a085; }
        .btn-orange { background-color: #e67e22; }
        .search-box { margin-bottom: 20px; display: flex; gap: 10px; flex-wrap: wrap; }
        .search-input { flex: 1; padding: 12px; border: 2px solid #ddd; border-radius: 8px; font-size: 14px; }
        .search-input:focus { outline: none; border-color: #3498db; }
        .table-wrapper { overflow-x: auto; border-radius: 12px; border: 1px solid #e0e0e0; }
        table { width: 100%; border-collapse: collapse; font-size: 14px; }
        th, td { border: 1px solid #ddd; padding: 12px; text-align: left; vertical-align: middle; }
        th { background-color: #34495e; color: white; font-weight: 600; }
        tr:nth-child(even) { background-color: #f9f9f9; }
        tr:hover { background-color: #f1f9ff; }
        .action-btn { padding: 5px 10px; margin: 0 3px; border: none; border-radius: 4px; cursor: pointer; font-size: 12px; font-weight: 600; color: white; }
        .edit-btn { background-color: #f39c12; }
        .delete-btn { background-color: #e74c3c; }
        .navigate-btn { background-color: #1abc9c; }
        .modal {
            display: none;
            position: fixed;
            z-index: 1000;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0,0,0,0.5);
            overflow-y: auto;
        }
        .modal-content {
            background-color: white;
            margin: 20px auto;
            padding: 25px;
            border-radius: 16px;
            width: 90%;
            max-width: 750px;
            position: relative;
        }
        .modal-content h3 { margin-top: 0; margin-bottom: 15px; color: #2c3e50; padding-bottom: 10px; border-bottom: 2px solid #ecf0f1; }
        .modal-scroll-area { max-height: calc(90vh - 120px); overflow-y: auto; padding-right: 5px; }
        .modal-content input, .modal-content textarea { width: 100%; padding: 10px; margin: 8px 0; border: 1px solid #ddd; border-radius: 6px; font-size: 14px; }
        .modal-content textarea { resize: vertical; min-height: 60px; }
        .modal-buttons { display: flex; gap: 12px; justify-content: flex-end; margin-top: 20px; padding-top: 15px; border-top: 1px solid #ecf0f1; background: white; }
        .map-modal-container { margin: 10px 0; border-radius: 12px; overflow: hidden; border: 1px solid #ddd; height: 300px; }
        #modalMap { height: 100%; width: 100%; }
        .map-control-buttons { display: flex; gap: 10px; margin-top: 10px; flex-wrap: wrap; }
        .map-btn { background: #eef3f7; border: none; border-radius: 2rem; padding: 8px 16px; font-size: 0.8rem; font-weight: 500; cursor: pointer; color: #1a6d7c; transition: 0.2s; }
        .map-btn:hover { background: #d4e4ea; }
        .coord-info { font-size: 12px; color: #666; margin-top: 8px; padding: 8px; background: #f0f8ff; border-radius: 8px; }
        .member-section { background: #f0f8ff; padding: 15px; border-radius: 10px; margin: 15px 0; border: 1px solid #b8e1fc; }
        .member-list { background: white; padding: 10px; border-radius: 8px; margin: 10px 0; max-height: 100px; overflow-y: auto; }
        .member-tag { display: inline-block; background: #3498db; color: white; padding: 3px 8px; border-radius: 15px; font-size: 11px; margin: 2px; }
        .input-member { display: flex; gap: 8px; margin-top: 10px; flex-wrap: wrap; }
        .input-member input { flex: 2; min-width: 150px; margin: 0; }
        .bulk-area { margin-top: 20px; padding: 15px; background: #f8f9fa; border-radius: 8px; display: none; }
        .stats { margin-top: 15px; padding: 10px; background: #ecf0f1; border-radius: 8px; font-size: 14px; }
        .info-badge { background: #e67e22; color: white; padding: 4px 12px; border-radius: 20px; font-size: 12px; margin-left: 10px; }
        .install-banner { background: linear-gradient(135deg, #27ae60, #2ecc71); color: white; padding: 12px 16px; border-radius: 12px; margin-bottom: 20px; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; }
        .label-text { font-weight: 600; color: #2c3e50; margin-top: 10px; display: block; }
        .geocoder-control { margin-bottom: 10px; }
        .leaflet-control-geocoder-form { display: flex; gap: 5px; }
        .leaflet-control-geocoder-form input { width: 100%; padding: 8px; border-radius: 20px; border: 1px solid #ddd; }
        @media (max-width: 768px) {
            body { padding: 10px; }
            .modal-content { margin: 10px auto; width: 95%; padding: 15px; }
        }
    </style>
</head>
<body>
    <div class="main-container">
        <div id="installBanner" class="install-banner" style="display: none;">
            <span>📱 Install aplikasi ini ke layar utama</span>
            <button id="installBtn">Install Sekarang</button>
        </div>
        
        <h1>🗺️ Sensus Keluarga JATIM 
            <span class="info-badge">✨ Pencarian Alamat Akurat</span>
        </h1>
        <div class="subtitle">Masukkan alamat lengkap → klik "Cari Alamat" → peta akan menunjuk lokasi | Geser marker jika perlu koreksi</div>
        
        <div class="button-panel">
            <button class="btn btn-primary" onclick="openAddModal()">➕ Tambah Data</button>
            <button class="btn btn-info" onclick="toggleBulkMode()">📊 Tambah Banyak</button>
            <button class="btn btn-warning" onclick="exportData()">💾 Export JSON</button>
            <button class="btn btn-success" onclick="importData()">📂 Import JSON</button>
        </div>
        
        <div class="search-box">
            <input type="text" id="searchInput" class="search-input" placeholder="🔍 Cari nama, alamat, atau keterangan..." onkeyup="quickSearch()">
            <button class="btn btn-primary" onclick="quickSearch()">Cari</button>
            <button class="btn btn-warning" onclick="clearSearch()">Reset</button>
        </div>
        
        <div id="bulkArea" class="bulk-area">
            <h3>Tambah Banyak Data</h3>
            <p>Format: <strong>Nama | Alamat | Keterangan | Lat | Lng</strong></p>
            <textarea id="bulkData" rows="6" placeholder="Contoh:
Toko Kenzie | Semanding, Tertek, Kec. Pare, Kab. Kediri, Jawa Timur | Variasi Motor | -7.776 | 112.198"></textarea>
            <div class="modal-buttons" style="border-top: none; padding-top: 0;">
                <button class="btn btn-success" onclick="processBulkAdd()">Proses</button>
                <button class="btn btn-danger" onclick="toggleBulkMode()">Tutup</button>
            </div>
        </div>
        
        <div class="table-wrapper">
            <table id="dataTable">
                <thead><tr><th>No</th><th>Nama</th><th>Alamat</th><th>Keterangan</th><th>Aksi</th></tr></thead>
                <tbody id="tableBody"><tr><td colspan="5">Memuat data...</td></tr></tbody>
            </table>
        </div>
        
        <div class="stats">Total data: <span id="totalCount">0</span> | Menampilkan: <span id="displayCount">0</span></div>
    </div>
    
    <!-- MODAL -->
    <div id="modal" class="modal">
        <div class="modal-content">
            <h3 id="modalTitle">Tambah Data</h3>
            <div class="modal-scroll-area">
                <label class="label-text">Nama Lengkap:</label>
                <input type="text" id="inputNama" placeholder="Nama lengkap">
                
                <label class="label-text">Alamat Lengkap (Jawa Timur):</label>
                <textarea id="inputAlamat" rows="2" placeholder="Contoh: Toko Kenzie, Semanding, Tertek, Kec. Pare, Kab. Kediri, Jawa Timur"></textarea>
                
                <label class="label-text">🗺️ Cari Lokasi:</label>
                <div class="map-modal-container"><div id="modalMap"></div></div>
                <div class="map-control-buttons">
                    <button type="button" id="geocodeModalBtn" class="map-btn">🔍 Cari Alamat (Akurat)</button>
                    <button type="button" id="currentLocationBtn" class="map-btn">📍 Lokasi Saya</button>
                </div>
                <div id="coordInfo" class="coord-info">💡 Tips: Klik 'Cari Alamat' setelah mengisi alamat lengkap. Jika tidak ditemukan, geser marker ke lokasi yang benar.</div>
                <input type="hidden" id="inputLat" value="">
                <input type="hidden" id="inputLng" value="">
                
                <label class="label-text">Keterangan:</label>
                <textarea id="inputKeterangan" rows="2" placeholder="Keterangan"></textarea>
                
                <div id="memberSection" class="member-section" style="display: none;">
                    <h4>👥 Daftar Anggota Keluarga</h4>
                    <div id="memberList" class="member-list"></div>
                    <div class="input-member">
                        <input type="text" id="newMemberInput" placeholder="Nama anggota baru (pisah koma)">
                        <button class="btn btn-orange" onclick="addMembersToCurrent()">➕ Tambah</button>
                    </div>
                </div>
            </div>
            <div class="modal-buttons">
                <button class="btn btn-success" onclick="saveData()">✅ Simpan</button>
                <button class="btn btn-danger" onclick="closeModal()">❌ Batal</button>
            </div>
        </div>
    </div>
    
    <script>
        // ==================== DATA STORE ====================
        let dataStore = [];
        let editIndex = -1;
        let currentSearchTerm = '';
        let modalMap, modalMarker;
        
        // Data awal dengan koordinat Toko Kenzie (estimasi)
        function initSampleData() {
            return [
                { nama: "Toko Kenzie", alamat: "Semanding, Tertek, Kec. Pare, Kab. Kediri, Jawa Timur", keterangan: "Variasi Motor", lat: -7.776, lng: 112.198 },
                { nama: "Seblak DearNathan", alamat: "Ngantru, Tulungagung, Jawa Timur", keterangan: "Kuliner", lat: -8.026373, lng: 111.938938 },
                { nama: "Ahmad Wijaya", alamat: "Jl. Merdeka No. 12, Surabaya, Jawa Timur", keterangan: "Karyawan tetap", lat: -7.2575, lng: 112.7521 }
            ];
        }
        
        function loadDataFromStorage() {
            const saved = localStorage.getItem('sensusJatimDataV3');
            if (saved) {
                try {
                    const parsed = JSON.parse(saved);
                    if (Array.isArray(parsed) && parsed.length > 0) {
                        dataStore = parsed;
                        dataStore.forEach(item => {
                            if (!item.lat || !item.lng) { item.lat = -7.776; item.lng = 112.198; }
                        });
                        return;
                    }
                } catch(e) {}
            }
            dataStore = initSampleData();
            saveToStorage();
        }
        
        function saveToStorage() { localStorage.setItem('sensusJatimDataV3', JSON.stringify(dataStore)); }
        function escapeHtml(str) { if (!str) return ''; return str.replace(/[&<>]/g, m => m==='&'?'&amp;':m==='<'?'&lt;':'&gt;'); }
        
        // Parse Nama & Anggota
        function parseNamaWithMembers(fullName) {
            const memberPattern = /^(.+?)\s*\(Anggota:\s*(.+?)\)$/;
            const match = fullName.match(memberPattern);
            if (match) return { baseName: match[1].trim(), members: match[2].split(',').map(m => m.trim()) };
            return { baseName: fullName, members: [] };
        }
        
        function combineNameWithMembers(baseName, members) {
            if (!members || members.length === 0) return baseName;
            return `${baseName} (Anggota: ${members.join(', ')})`;
        }
        
        function updateMemberSection() {
            const memberSection = document.getElementById('memberSection');
            const memberListDiv = document.getElementById('memberList');
            const inputNama = document.getElementById('inputNama').value;
            if (editIndex === -1) { memberSection.style.display = 'none'; return; }
            memberSection.style.display = 'block';
            const parsed = parseNamaWithMembers(inputNama);
            if (parsed.members.length === 0) {
                memberListDiv.innerHTML = '<span style="color: #999;">Belum ada anggota</span>';
            } else {
                let html = '<strong>👥 Anggota saat ini:</strong><br>';
                parsed.members.forEach(member => { html += `<span class="member-tag">👤 ${escapeHtml(member)}</span> `; });
                memberListDiv.innerHTML = html;
            }
        }
        
        function addMembersToCurrent() {
            const input = document.getElementById('newMemberInput');
            let newMembersText = input.value.trim();
            if (!newMembersText) { alert('Masukkan nama anggota!'); return; }
            let currentNama = document.getElementById('inputNama').value;
            const parsed = parseNamaWithMembers(currentNama);
            let newMembers = newMembersText.split(',').map(m => m.trim()).filter(m => m);
            let allMembers = [...parsed.members, ...newMembers];
            const uniqueMembers = [];
            const seen = new Set();
            for (let member of allMembers) {
                const lower = member.toLowerCase();
                if (!seen.has(lower)) { seen.add(lower); uniqueMembers.push(member); }
            }
            const newNama = combineNameWithMembers(parsed.baseName, uniqueMembers);
            document.getElementById('inputNama').value = newNama;
            document.getElementById('newMemberInput').value = '';
            updateMemberSection();
            alert(`✅ Berhasil menambahkan ${newMembers.length} anggota baru`);
        }
        
        // Navigasi ke Google Maps
        function navigateToAddress(lat, lng, alamat) {
            if (lat && lng && !isNaN(lat) && !isNaN(lng)) {
                window.open(`https://www.google.com/maps/dir/?api=1&destination=${lat},${lng}&travelmode=driving`, '_blank');
            } else {
                window.open(`https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(alamat)}`, '_blank');
            }
        }
        
        // Render Tabel
        function renderTable() {
            const searchTerm = currentSearchTerm.toLowerCase().trim();
            let filteredData = searchTerm ? dataStore.filter(item => 
                item.nama.toLowerCase().includes(searchTerm) || 
                item.alamat.toLowerCase().includes(searchTerm) || 
                (item.keterangan && item.keterangan.toLowerCase().includes(searchTerm))
            ) : dataStore;
            
            const tbody = document.getElementById('tableBody');
            if (filteredData.length === 0) {
                tbody.innerHTML = '<tr><td colspan="5" style="text-align:center">Tidak ada数据</td></tr>';
                document.getElementById('displayCount').innerText = '0';
                document.getElementById('totalCount').innerText = dataStore.length;
                return;
            }
            let html = '';
            filteredData.forEach((item, idx) => {
                const originalIndex = dataStore.findIndex(orig => orig.nama === item.nama && orig.alamat === item.alamat);
                const parsed = parseNamaWithMembers(item.nama);
                let namaDisplay = escapeHtml(parsed.baseName);
                if (parsed.members.length > 0) namaDisplay += `<span style="font-size: 10px; color: #e67e22;"> (+${parsed.members.length})</span>`;
                html += `<tr>
                    <td>${idx + 1}</td>
                    <td>${namaDisplay}</td>
                    <td>${escapeHtml(item.alamat)}</td>
                    <td>${escapeHtml(item.keterangan || '-')}</td>
                    <td>
                        <button class="action-btn edit-btn" onclick="openEditModal(${originalIndex})">✏️ Edit</button>
                        <button class="action-btn navigate-btn" onclick="navigateToAddress(${item.lat}, ${item.lng}, '${escapeHtml(item.alamat)}')">🧭 Navigasi</button>
                        <button class="action-btn delete-btn" onclick="deleteData(${originalIndex})">🗑️ Hapus</button>
                    </td>
                </tr>`;
            });
            tbody.innerHTML = html;
            document.getElementById('displayCount').innerText = filteredData.length;
            document.getElementById('totalCount').innerText = dataStore.length;
        }
        
        function quickSearch() { currentSearchTerm = document.getElementById('searchInput').value; renderTable(); }
        function clearSearch() { document.getElementById('searchInput').value = ''; currentSearchTerm = ''; renderTable(); }
        
        // ==================== MAPS AKURAT - Multi Provider Geocoding ====================
        function initModalMap() {
            const defaultLoc = [-7.776, 112.198]; // Kediri area
            modalMap = L.map('modalMap').setView(defaultLoc, 13);
            L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', {
                attribution: '&copy; OpenStreetMap | Indonesia'
            }).addTo(modalMap);
            modalMarker = L.marker(defaultLoc, { draggable: true }).addTo(modalMap);
            
            modalMarker.on('dragend', function(e) {
                const pos = modalMarker.getLatLng();
                document.getElementById('inputLat').value = pos.lat;
                document.getElementById('inputLng').value = pos.lng;
                document.getElementById('coordInfo').innerHTML = `📍 Marker digeser ke: ${pos.lat.toFixed(6)}, ${pos.lng.toFixed(6)}`;
            });
            modalMap.on('click', function(e) {
                modalMarker.setLatLng(e.latlng);
                document.getElementById('inputLat').value = e.latlng.lat;
                document.getElementById('inputLng').value = e.latlng.lng;
                document.getElementById('coordInfo').innerHTML = `📍 Posisi dipilih: ${e.latlng.lat.toFixed(6)}, ${e.latlng.lng.toFixed(6)}`;
            });
        }
        
        // Geocoding dengan Google Maps Geocoder (lebih akurat untuk Indonesia)
        async function geocodeWithGoogle(address) {
            return new Promise((resolve, reject) => {
                // Gunakan Google Maps Geocoding API (public, limited)
                const url = `https://maps.googleapis.com/maps/api/geocode/json?address=${encodeURIComponent(address + ", Indonesia")}&sensor=false`;
                fetch(url)
                    .then(res => res.json())
                    .then(data => {
                        if (data.status === "OK" && data.results && data.results.length > 0) {
                            const lat = data.results[0].geometry.location.lat;
                            const lng = data.results[0].geometry.location.lng;
                            const formatted = data.results[0].formatted_address;
                            resolve({ lat, lng, formatted });
                        } else {
                            reject(new Error("Google tidak menemukan alamat"));
                        }
                    })
                    .catch(reject);
            });
        }
        
        // Geocoding dengan Nominatim (OpenStreetMap)
        async function geocodeWithNominatim(address) {
            return new Promise((resolve, reject) => {
                const url = `https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(address + ", Jawa Timur, Indonesia")}&limit=1&countrycodes=id`;
                fetch(url)
                    .then(res => res.json())
                    .then(data => {
                        if (data && data.length > 0) {
                            const lat = parseFloat(data[0].lat);
                            const lng = parseFloat(data[0].lon);
                            const formatted = data[0].display_name;
                            resolve({ lat, lng, formatted });
                        } else {
                            reject(new Error("Nominatim tidak menemukan alamat"));
                        }
                    })
                    .catch(reject);
            });
        }
        
        async function geocodeAddressAkurat() {
            const address = document.getElementById('inputAlamat').value.trim();
            if (!address) { alert("Masukkan alamat lengkap terlebih dahulu!"); return; }
            
            const statusDiv = document.getElementById('coordInfo');
            statusDiv.innerHTML = "🔍 Mencari alamat... (mencoba Google Maps)";
            statusDiv.style.color = "#e67e22";
            
            // Coba Google Maps dulu (lebih akurat)
            try {
                const result = await geocodeWithGoogle(address);
                document.getElementById('inputLat').value = result.lat;
                document.getElementById('inputLng').value = result.lng;
                modalMap.setView([result.lat, result.lng], 16);
                modalMarker.setLatLng([result.lat, result.lng]);
                if (result.formatted) document.getElementById('inputAlamat').value = result.formatted;
                statusDiv.innerHTML = `✅ Alamat ditemukan (Google Maps)! Koordinat: ${result.lat.toFixed(6)}, ${result.lng.toFixed(6)}`;
                statusDiv.style.color = "#27ae60";
                return;
            } catch(e) {
                console.log("Google gagal, coba Nominatim", e);
                statusDiv.innerHTML = "🔄 Google tidak menemukan, mencoba OpenStreetMap...";
            }
            
            // Fallback ke Nominatim
            try {
                const result = await geocodeWithNominatim(address);
                document.getElementById('inputLat').value = result.lat;
                document.getElementById('inputLng').value = result.lng;
                modalMap.setView([result.lat, result.lng], 16);
                modalMarker.setLatLng([result.lat, result.lng]);
                if (result.formatted) document.getElementById('inputAlamat').value = result.formatted;
                statusDiv.innerHTML = `✅ Alamat ditemukan (OpenStreetMap)! Koordinat: ${result.lat.toFixed(6)}, ${result.lng.toFixed(6)}`;
                statusDiv.style.color = "#27ae60";
                return;
            } catch(e) {
                console.log("Semua geocoder gagal", e);
            }
            
            // Jika semua gagal, beri petunjuk manual
            statusDiv.innerHTML = "⚠️ Alamat tidak ditemukan secara otomatis. Silakan geser marker ke lokasi yang benar pada peta, lalu simpan.";
            statusDiv.style.color = "#e74c3c";
            alert("Alamat tidak dapat ditemukan secara otomatis.\n\nKlik 'OK' lalu geser marker (icon merah) pada peta ke lokasi yang benar, kemudian klik Simpan.\n\nTips: Gunakan alamat lengkap seperti 'Toko Kenzie, Semanding, Tertek, Kec. Pare, Kab. Kediri'");
        }
        
        function getCurrentLocationModal() {
            if (navigator.geolocation) {
                navigator.geolocation.getCurrentPosition(pos => {
                    const lat = pos.coords.latitude, lng = pos.coords.longitude;
                    document.getElementById('inputLat').value = lat;
                    document.getElementById('inputLng').value = lng;
                    document.getElementById('coordInfo').innerHTML = `📍 Lokasi Anda: ${lat.toFixed(6)}, ${lng.toFixed(6)}`;
                    modalMap.setView([lat, lng], 15);
                    modalMarker.setLatLng([lat, lng]);
                    
                    // Reverse geocode untuk isi alamat
                    fetch(`https://nominatim.openstreetmap.org/reverse?format=json&lat=${lat}&lon=${lng}&zoom=18`)
                        .then(res => res.json())
                        .then(data => { if(data.display_name) document.getElementById('inputAlamat').value = data.display_name; })
                        .catch(() => {});
                }, () => alert("Gagal mendapat lokasi, pastikan izin diberikan"));
            } else { alert("Browser tidak support geolocation"); }
        }
        
        // CRUD
        function openAddModal() {
            editIndex = -1;
            document.getElementById('modalTitle').innerText = '➕ Tambah Data Baru';
            document.getElementById('inputNama').value = '';
            document.getElementById('inputAlamat').value = '';
            document.getElementById('inputKeterangan').value = '';
            document.getElementById('inputLat').value = '-7.776';
            document.getElementById('inputLng').value = '112.198';
            document.getElementById('newMemberInput').value = '';
            document.getElementById('coordInfo').innerHTML = '📍 Default: Area Kediri (geser marker untuk koreksi)';
            document.getElementById('memberSection').style.display = 'none';
            if (modalMap) { modalMap.setView([-7.776, 112.198], 12); modalMarker.setLatLng([-7.776, 112.198]); }
            document.getElementById('modal').style.display = 'block';
            document.body.style.overflow = 'hidden';
        }
        
        function openEditModal(index) {
            if (index < 0 || index >= dataStore.length) return;
            editIndex = index;
            const item = dataStore[index];
            document.getElementById('modalTitle').innerText = '✏️ Edit Data & Tambah Anggota';
            document.getElementById('inputNama').value = item.nama;
            document.getElementById('inputAlamat').value = item.alamat;
            document.getElementById('inputKeterangan').value = item.keterangan || '';
            document.getElementById('inputLat').value = item.lat || -7.776;
            document.getElementById('inputLng').value = item.lng || 112.198;
            document.getElementById('newMemberInput').value = '';
            document.getElementById('coordInfo').innerHTML = `📍 Koordinat: ${(item.lat || -7.776).toFixed(6)}, ${(item.lng || 112.198).toFixed(6)}`;
            if (modalMap) { modalMap.setView([item.lat || -7.776, item.lng || 112.198], 14); modalMarker.setLatLng([item.lat || -7.776, item.lng || 112.198]); }
            updateMemberSection();
            document.getElementById('modal').style.display = 'block';
            document.body.style.overflow = 'hidden';
        }
        
        function saveData() {
            let nama = document.getElementById('inputNama').value.trim();
            const alamat = document.getElementById('inputAlamat').value.trim();
            const keterangan = document.getElementById('inputKeterangan').value.trim();
            let lat = parseFloat(document.getElementById('inputLat').value);
            let lng = parseFloat(document.getElementById('inputLng').value);
            if (!nama) { alert('Nama harus diisi!'); return; }
            if (!alamat) { alert('Alamat harus diisi!'); return; }
            if (isNaN(lat) || isNaN(lng)) { lat = -7.776; lng = 112.198; }
            if (editIndex === -1) dataStore.push({ nama, alamat, keterangan, lat, lng });
            else dataStore[editIndex] = { nama, alamat, keterangan, lat, lng };
            saveToStorage();
            closeModal();
            clearSearch();
            renderTable();
            alert('✅ Data berhasil disimpan!');
        }
        
        function deleteData(index) {
            if (confirm('Yakin ingin menghapus data ini?')) { dataStore.splice(index, 1); saveToStorage(); renderTable(); }
        }
        
        function closeModal() { document.getElementById('modal').style.display = 'none'; document.body.style.overflow = 'auto'; editIndex = -1; }
        function toggleBulkMode() { const area = document.getElementById('bulkArea'); area.style.display = area.style.display === 'none' ? 'block' : 'none'; }
        
        function processBulkAdd() {
            const rawText = document.getElementById('bulkData').value;
            if (!rawText.trim()) { alert('Masukkan data!'); return; }
            const lines = rawText.split(/\r?\n/);
            let addedCount = 0;
            for (let line of lines) {
                line = line.trim();
                if (line === '') continue;
                const parts = line.split('|').map(s => s.trim());
                if (parts.length >= 3) {
                    const nama = parts[0], alamat = parts[1], keterangan = parts[2];
                    let lat = parts.length > 3 ? parseFloat(parts[3]) : -7.776;
                    let lng = parts.length > 4 ? parseFloat(parts[4]) : 112.198;
                    if (isNaN(lat)) lat = -7.776;
                    if (isNaN(lng)) lng = 112.198;
                    if (nama) { dataStore.push({ nama, alamat, keterangan, lat, lng }); addedCount++; }
                }
            }
            if (addedCount > 0) { saveToStorage(); renderTable(); alert(`Berhasil menambahkan ${addedCount} data.`); document.getElementById('bulkData').value = ''; toggleBulkMode(); }
            else alert('Format: Nama | Alamat | Keterangan | Lat | Lng');
        }
        
        function exportData() {
            const dataStr = JSON.stringify(dataStore, null, 2);
            const blob = new Blob([dataStr], {type: 'application/json'});
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = `sensus_jatim_${new Date().toISOString().slice(0,19)}.json`;
            a.click();
            URL.revokeObjectURL(url);
        }
        
        function importData() {
            const input = document.createElement('input');
            input.type = 'file';
            input.accept = '.json';
            input.onchange = function(e) {
                const file = e.target.files[0];
                if (!file) return;
                const reader = new FileReader();
                reader.onload = function(evt) {
                    try {
                        const imported = JSON.parse(evt.target.result);
                        if (Array.isArray(imported)) {
                            if (confirm(`Import ${imported.length} data?`)) { dataStore.push(...imported); saveToStorage(); renderTable(); alert(`Berhasil import ${imported.length} data`); }
                        } else alert('Format JSON tidak valid.');
                    } catch(err) { alert('Gagal membaca file: ' + err.message); }
                };
                reader.readAsText(file);
            };
            input.click();
        }
        
        // Event Listeners
        document.getElementById('inputNama')?.addEventListener('input', function() { if (editIndex !== -1) updateMemberSection(); });
        window.onclick = function(event) { if (event.target === document.getElementById('modal')) closeModal(); };
        
        // PWA
        let deferredPrompt;
        window.addEventListener('beforeinstallprompt', (e) => { e.preventDefault(); deferredPrompt = e; document.getElementById('installBanner').style.display = 'flex'; });
        document.getElementById('installBtn')?.addEventListener('click', async () => { if (deferredPrompt) { deferredPrompt.prompt(); deferredPrompt = null; document.getElementById('installBanner').style.display = 'none'; } });
        
        // Inisialisasi
        loadDataFromStorage();
        renderTable();
        initModalMap();
        document.getElementById('geocodeModalBtn')?.addEventListener('click', geocodeAddressAkurat);
        document.getElementById('currentLocationBtn')?.addEventListener('click', getCurrentLocationModal);
    </script>
</body>
</html>
